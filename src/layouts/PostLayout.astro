---
import '../styles/global.css';
import '../styles/post.css';
import AudioPlayer from '../components/AudioPlayer.astro';

export interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  audioUrl?: string;
  image?: { url: string; alt: string };
}

const { title, description, date, tags, audioUrl, image } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Chukwuma Theology</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
  </head>
  <body>

    <header class="site-header">
      <nav class="site-nav container">
        <a href={base} class="logo">Chukwuma <span>Theology</span></a>
        <ul class="nav-links">
          <li><a href={`${base}#about`}>About</a></li>
          <li><a href={`${base}#studies`}>Bible Studies</a></li>
          <li><a href="https://chukwumatheology.substack.com/" target="_blank" rel="noopener">Substack</a></li>
          <li><a href={`${base}#contact`}>Connect</a></li>
        </ul>
      </nav>
    </header>

    {image && (
      <div class="post-hero">
        <img src={image.url} alt={image.alt} />
      </div>
    )}

    <article>
      <header>
        <h1>{title}</h1>
        <p class="post-description">{description}</p>
        <div class="post-meta">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          <span> · Chukwuma Onyeije</span>
        </div>
        {tags && tags.length > 0 && (
          <div class="tags">
            {tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        )}
      </header>

      {audioUrl && <AudioPlayer src={audioUrl} title={title} />}

      <div class="prose">
        <slot />
      </div>
    </article>

    <footer class="site-footer">
      <div class="container">
        <p>&copy; 2026 Chukwuma I. Onyeije, MD. Faith-based reflections for a modern world.</p>
      </div>
    </footer>

  </body>
</html>
