---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const isDev = import.meta.env.DEV;
const posts = (await getCollection('posts', ({ data }) => isDev || !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chukwuma Theology | Theology, Truth, and Christian Reflection</title>
    <meta name="description" content="Exploring the intersection of Seventh-day Adventist theology, biblical truth, and our shared history." />
    <style>
      /* ── Hero ───────────────────────────────────── */
      .hero {
        background:
          linear-gradient(rgba(45, 71, 57, 0.82), rgba(45, 71, 57, 0.82)),
          url('https://images.unsplash.com/photo-1507413245164-6160d8298b31?auto=format&fit=crop&q=80&w=2070')
          center / cover no-repeat;
        color: var(--white);
        padding: 100px 0;
        text-align: center;
      }

      .hero h1 {
        font-family: 'Playfair Display', serif;
        font-size: 3rem;
        line-height: 1.2;
        margin-bottom: 20px;
        color: var(--white);
      }

      .hero p {
        font-size: 1.15rem;
        max-width: 680px;
        margin: 0 auto 30px;
        opacity: 0.9;
      }

      /* ── Posts grid ─────────────────────────────── */
      .posts-section {
        padding: 80px 0;
      }

      .section-title {
        text-align: center;
        margin-bottom: 50px;
      }

      .section-title h2 {
        font-family: 'Playfair Display', serif;
        font-size: 2.25rem;
        color: var(--primary);
        margin-bottom: 10px;
      }

      .section-title p {
        color: var(--text-muted);
        font-size: 1rem;
      }

      .card-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
      }

      .card {
        background: var(--white);
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        border-top: 5px solid var(--accent);
        transition: transform 0.25s;
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }

      .card:hover { transform: translateY(-5px); }

      .card-img {
        width: 100%;
        height: 200px;
        object-fit: cover;
        display: block;
        flex-shrink: 0;
      }

      .card-body {
        padding: 28px 32px 32px;
        display: flex;
        flex-direction: column;
        flex: 1;
      }

      .card-tag {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--secondary);
        font-weight: 700;
        margin-bottom: 12px;
      }

      .card h3 {
        font-family: 'Playfair Display', serif;
        font-size: 1.25rem;
        color: var(--primary);
        margin-bottom: 12px;
        line-height: 1.3;
      }

      .card p {
        font-size: 0.95rem;
        color: #555;
        flex: 1;
      }

      .card-meta {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-top: 8px;
      }

      .read-more {
        display: inline-block;
        margin-top: 20px;
        color: var(--primary);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
      }

      .read-more:hover { color: var(--secondary); }

      /* ── About strip ────────────────────────────── */
      .about-strip {
        background: var(--primary);
        color: var(--white);
        padding: 70px 0;
        text-align: center;
      }

      .about-strip h2 {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        color: var(--accent);
        margin-bottom: 16px;
      }

      .about-strip p {
        max-width: 680px;
        margin: 0 auto;
        opacity: 0.9;
        font-size: 1rem;
        line-height: 1.7;
      }
    </style>
  </head>
  <body>

    <header class="site-header">
      <nav class="site-nav container">
        <a href={base} class="logo">Chukwuma <span>Theology</span></a>
        <ul class="nav-links">
          <li><a href="#about">About</a></li>
          <li><a href="#studies">Bible Studies</a></li>
          <li><a href="https://chukwumatheology.substack.com/" target="_blank" rel="noopener">Substack</a></li>
          <li><a href="#contact">Connect</a></li>
        </ul>
      </nav>
    </header>

    <section class="hero">
      <div class="container">
        <h1>Theology, Truth, and Christian Reflection</h1>
        <p>Exploring the intersection of Seventh-day Adventist theology, biblical truth, and our shared history.</p>
        <a href="#studies" class="btn">Start Exploring</a>
      </div>
    </section>

    <main>

      <section id="studies" class="posts-section">
        <div class="container">
          <div class="section-title">
            <h2>Latest Reflections</h2>
            <p>Actionable insights for deeper scriptural understanding.</p>
          </div>

          <div class="card-container">
            {posts.map((post) => (
              <article class="card">
                {post.data.image && (
                  <img class="card-img" src={post.data.image.url} alt={post.data.image.alt} />
                )}
                <div class="card-body">
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="card-tag">{post.data.tags[0]}</div>
                  )}
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                  <div class="card-meta">
                    {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </div>
                  <a href={`${base}/posts/${post.slug}/`} class="read-more">Read More →</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="about" class="about-strip">
        <div class="container">
          <h2>About This Space</h2>
          <p>
            I am Chukwuma I. Onyeije, MD, FACOG — a physician, Seventh-day Adventist, and student of scripture.
            This blog is where medicine, theology, and thoughtful reflection meet.
            Every post is an invitation to think more carefully about what we believe and why.
          </p>
        </div>
      </section>

    </main>

    <footer id="contact" class="site-footer">
      <div class="container">
        <p>&copy; 2026 Chukwuma I. Onyeije, MD. Faith-based reflections for a modern world.</p>
      </div>
    </footer>

  </body>
</html>
